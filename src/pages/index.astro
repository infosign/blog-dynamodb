---
import { getAllArticles } from '../lib/api';

const articles = await getAllArticles();
articles.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog (DynamoDB)</title>
  <style>
    body { font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 2rem; }
    h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
    .db-label { font-size: 0.85rem; color: #3730a3; font-weight: 600; margin-bottom: 1.5rem; }
    .badge { display: inline-block; background: #e0e7ff; color: #3730a3; font-size: 0.7rem; padding: 2px 8px; border-radius: 4px; margin-right: 4px; }
    ul { list-style: none; padding: 0; }
    li { border-bottom: 1px solid #e5e7eb; padding: 1rem 0; }
    li:last-child { border-bottom: none; }
    a { text-decoration: none; color: #1d4ed8; font-size: 1.1rem; font-weight: 500; }
    a:hover { text-decoration: underline; }
    .meta { font-size: 0.8rem; color: #6b7280; margin-top: 4px; }
  </style>
</head>
<body>
  <h1>記事一覧</h1>
  <p class="db-label">Database: DynamoDB</p>
  {articles.length === 0 && <p>記事がありません。</p>}
  <ul>
    {articles.map(article => (
      <li>
        <a href={`/articles/${article.article_id}`}>{article.title}</a>
        <div class="meta">
          {article.author_name || article.author_id} &nbsp;|&nbsp;
          {new Date(article.created_at).toLocaleDateString('ja-JP')}
          &nbsp;
          {article.tags?.map(tag => <span class="badge">{tag}</span>)}
        </div>
      </li>
    ))}
  </ul>
</body>
</html>
